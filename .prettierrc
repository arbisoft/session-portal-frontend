{
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "es5",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "arrowParens": "always",
  "endOfLine": "lf",
  "jsxSingleQuote": false,
  "printWidth": 130,
  "overrides": [
    {
      "files": "*.md",
      "options": {
        "embeddedLanguageFormatting": "auto",
        "htmlWhitespaceSensitivity": "css",
        "insertPragma": false,
        "proseWrap": "never",
        "quoteProps": "as-needed",
        "requirePragma": false,
        "singleAttributePerLine": false,
        "vueIndentScriptAndStyle": false
      }
    }
  ]
}
